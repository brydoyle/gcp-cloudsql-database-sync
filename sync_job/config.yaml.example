# CloudSQL Sync Configuration
# Copy this file to config.yaml and fill in your values, or run:
#   python3 configure.py

prod_project_id: your-prod-project-id
prod_instance_name: your-prod-instance-name

nonprod_project_id: your-nonprod-project-id
nonprod_instance_name: your-nonprod-instance-name

region: us-central1

# Schedule: a 5-field cron expression, or "on-demand" for no scheduler
# (run only when triggered manually / by CI). `configure.py` builds this
# interactively. Default below = every Saturday night at 23:00.
#   daily 02:00    → "0 2 * * *"
#   weekdays 02:00 → "0 2 * * 1-5"
#   on-demand      → "on-demand"
schedule: "0 23 * * 6"
timezone: UTC

# Cloud Run Job name — change only if you need multiple sync jobs
job_name: cloudsql-sync

# Reuse the most recent EXISTING backup of the prod instance instead of
# creating a new one each run. When true, the reused backup is never deleted
# by the job. Default false (create a fresh on-demand backup every run).
use_latest_existing_backup: "false"
